{
  "manifest_version": 2,
  "name": "The Missing Link",
  "version": "0.3.0",
  "description": "Find the case the article didn't link. Claude identifies the case discussed on the page; the extension links you straight to it on CourtListener.",
  "author": "Rebecca Fordon",
  "homepage_url": "https://github.com/rlfordon/the-missing-link",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "https://api.anthropic.com/*",
    "https://www.courtlistener.com/*"
  ],
  "browser_action": {
    "default_title": "Find on CourtListener",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "the-missing-link@rlfordon.github.io",
      "strict_min_version": "109.0"
    }
  }
}
